# Copy to ".env" and adjust. Used by docker-compose for non-secret settings.
# The Firefly TOKEN is NOT set here -> it lives in ./secrets/firefly_token.txt
# (mounted as a docker secret at /run/secrets/firefly_token).

# --- Firefly III connection ---
# URL reachable from inside the container.
FIREFLY_URL=http://host.docker.internal:8081
# Alternatively, if Firefly is reachable via its https name from the container:
# FIREFLY_URL=https://firefly.deubitos.de

# --- Conversion defaults ---
# Your own member name in MoneyBuster/Cospend (drives share + mode logic).
SELF_NAME=Oliver
DEFAULT_CURRENCY=EUR
IMPORT_TAG=moneybuster
# Default Firefly asset account (source/destination) when none is picked in the
# UI. Leave empty to force an explicit choice. NEVER reuses the expense account.
DEFAULT_ASSET_ACCOUNT=Girokonto
DEFAULT_EXPENSE_ACCOUNT=MoneyBuster
DEFAULT_CATEGORY=Sonstiges

# Map MoneyBuster/Cospend payment modes to Firefly asset accounts (JSON, keys
# case-insensitive). The source account of an import is derived from the
# bill's payment mode first, then the form choice, then DEFAULT_ASSET_ACCOUNT.
# NOTE: the MoneyBuster CSV stores short codes (e.g. c, n, b, t) -> map those.
PAYMENT_MODE_ACCOUNT_MAP={"cash":"Bargeld","bar":"Bargeld","bargeld":"Bargeld","card":"Girokonto","karte":"Girokonto","ec":"Girokonto","creditcard":"Kreditkarte","kreditkarte":"Kreditkarte","bank":"Girokonto","überweisung":"Girokonto","transfer":"Girokonto"}

# --- Firefly write behaviour ---
# Create missing expense accounts / categories in Firefly (default: off).
AUTO_CREATE_EXPENSE_ACCOUNTS=false
AUTO_CREATE_CATEGORIES=false
# Ask Firefly to reject duplicates (extra safety on top of local history).
ERROR_IF_DUPLICATE=true
# Apply Firefly's rule engine to imported transactions.
APPLY_RULES=false

# --- Local dev only (compose sets these itself) ---
# DATA_DIR=./data
