# Copy to ".env" and adjust. All values are optional for preview / CSV export;
# FIREFLY_BASE_URL and FIREFLY_TOKEN are required for the direct API upload.

# --- Firefly III connection ---
# Base URL of your Firefly III instance (no trailing /api).
FIREFLY_BASE_URL=https://firefly.example.ts.net
# Personal Access Token: Firefly III -> Options -> Profile -> OAuth.
FIREFLY_TOKEN=

# --- Conversion defaults (overridable per upload in the web form) ---
DEFAULT_ASSET_ACCOUNT=MoneyBuster
DEFAULT_EXPENSE_ACCOUNT=MoneyBuster Expenses
DEFAULT_REVENUE_ACCOUNT=MoneyBuster Income
DEFAULT_CURRENCY=EUR
IMPORT_TAG=moneybuster

# --- Behaviour ---
# true => positive amount becomes a deposit instead of a withdrawal.
INVERT_SIGN=false
# Ask Firefly to reject duplicates (based on the transaction hash).
ERROR_IF_DUPLICATE=true
# Apply Firefly's rule engine to imported transactions.
APPLY_RULES=false

# --- Networking (docker-compose) ---
# Interface to bind the published port to. Use your Tailscale IP (100.x.y.z)
# or keep 127.0.0.1 and expose via `tailscale serve`.
BIND_ADDR=127.0.0.1
